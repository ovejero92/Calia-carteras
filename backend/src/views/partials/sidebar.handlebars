<nav class="sidebar">
    <h3>🏪 Mi Tienda</h3>
    <ul>
        <li><a href="/owner">🏠 Inicio</a></li>
        <li><a href="/owner/categories">📂 Categorías</a></li>
        <li><a href="/owner/products">📦 Productos</a></li>
        <li><a href="/owner/users">👥 Usuarios</a></li>
        <li>
            <a href="/owner/sales">
                💰 Ventas 
                <span id="sales-badge" style="display:none; background:#dc3545; color:white; border-radius:50%; padding:2px 6px; font-size:12px; margin-left:5px; font-weight:bold;">0</span>
            </a>
        </li>
        <li><a href="/owner/front">🎨 Diseño Web</a></li>
        <li><button id="logout" class="btn-danger">🚪 Cerrar Sesión</button></li>
    </ul>
</nav>

<script>
    document.getElementById('logout')?.addEventListener('click', async () => {
        const response = await fetch('/owner/logout', { method: 'POST' });
        if (response.ok) window.location.href = '/owner/login';
    });

    const updateUnreadBadge = async () => {
        try {
            const res = await fetch('/owner/sales/unread-orders');
            if (res.ok) {
                const data = await res.json();
                const badge = document.getElementById('sales-badge');
                if (data.count > 0) {
                    badge.textContent = data.count > 99 ? '+99' : data.count;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            }
        } catch (e) {
            console.error('Error fetching unread orders', e);
        }
    };

    // Exponer globalmente para poder llamarla desde sales.handlebars
    window.updateUnreadBadge = updateUnreadBadge;

    // Consultar al cargar la página
    updateUnreadBadge();
    // Consultar cada 30 segundos
    setInterval(updateUnreadBadge, 30000);
</script>